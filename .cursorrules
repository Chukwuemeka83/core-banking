## 🎭 Synthetic Data Generation

**ALWAYS generate realistic test data for manual testing.**

### Seed Data Scripts

Create seed scripts in `scripts/seed/`:

```go
// scripts/seed/accounts.go
package main

import (
    "context"
    "fmt"
    "github.com/brianvoe/gofakeit/v6"
    "github.com/shopspring/decimal"
)

func seedAccounts(ctx context.Context, count int) error {
    for i := 0; i < count; i++ {
        account := &AccountProjection{
            ID:       uuid.New(),
            TenantID: tenantID,
            UserID:   uuid.New(),
            Balance:  decimal.NewFromFloat(gofakeit.Float64Range(100, 10000)),
            Currency: gofakeit.RandomString([]string{"USD", "EUR", "GBP", "AED"}),
            Status:   "active",
            CreatedAt: gofakeit.DateRange(
                time.Now().AddDate(0, -6, 0),
                time.Now(),
            ),
        }

        if err := db.Create(account).Error; err != nil {
            return err
        }

        // Generate transactions
        seedTransactions(ctx, account.ID, gofakeit.IntRange(10, 50))
    }

    return nil
}

func seedTransactions(ctx context.Context, accountID uuid.UUID, count int) error {
    types := []string{"deposit", "withdrawal", "transfer"}

    for i := 0; i < count; i++ {
        tx := &TransactionProjection{
            ID:        uuid.New(),
            AccountID: accountID,
            Type:      gofakeit.RandomString(types),
            Amount:    decimal.NewFromFloat(gofakeit.Float64Range(10, 1000)),
            Status:    "completed",
            CreatedAt: gofakeit.DateRange(
                time.Now().AddDate(0, -3, 0),
                time.Now(),
            ),
        }

        if err := db.Create(tx).Error; err != nil {
            return err
        }
    }

    return nil
}
```

### Seed Command

```bash
# Generate seed data
go run scripts/seed/main.go --accounts 100 --transactions 1000

# Reset and reseed
go run scripts/seed/main.go --reset --accounts 50
```

