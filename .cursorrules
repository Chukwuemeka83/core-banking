## 🏗️ Architecture Patterns

### 1. Event Sourcing with Event Horizon

**ALWAYS** use Event Horizon for aggregates:

```go
import "github.com/looplab/eventhorizon"

// Aggregate example
type AccountAggregate struct {
    *eventhorizon.AggregateBase
    balance    decimal.Decimal
    status     AccountStatus
    currency   string
    // ... other fields
}

// Factory function
func NewAccountAggregate(id uuid.UUID) *AccountAggregate {
    return &AccountAggregate{
        AggregateBase: eventhorizon.NewAggregateBase(AccountAggregateType, id),
    }
}

// Command handler
func (a *AccountAggregate) HandleCommand(ctx context.Context, cmd eventhorizon.Command) error {
    switch cmd := cmd.(type) {
    case *CreateAccountCommand:
        return a.handleCreateAccount(ctx, cmd)
    case *DepositCommand:
        return a.handleDeposit(ctx, cmd)
    // ... other commands
    }
    return fmt.Errorf("unknown command: %T", cmd)
}

// Business logic that emits events
func (a *AccountAggregate) handleDeposit(ctx context.Context, cmd *DepositCommand) error {
    // Validation
    if cmd.Amount.LessThanOrEqual(decimal.Zero) {
        return ErrInvalidAmount
    }

    // Emit event (don't mutate state here!)
    a.AppendEvent(DepositedEventType, &DepositedEvent{
        AccountID: a.EntityID(),
        Amount:    cmd.Amount,
        Currency:  cmd.Currency,
        Timestamp: time.Now(),
    }, time.Now())

    return nil
}

// Event handler (applies state changes)
func (a *AccountAggregate) ApplyEvent(ctx context.Context, event eventhorizon.Event) error {
    switch e := event.Data().(type) {
    case *AccountCreatedEvent:
        a.balance = decimal.Zero
        a.currency = e.Currency
        a.status = AccountStatusActive
    case *DepositedEvent:
        a.balance = a.balance.Add(e.Amount)
    case *WithdrawnEvent:
        a.balance = a.balance.Sub(e.Amount)
    // ... other events
    }
    return nil
}
```

**Rules:**
- ✅ Commands → validate and emit events
- ✅ Events → apply state changes
- ✅ Never mutate state in command handlers
- ✅ Events are immutable facts (past tense naming)
- ✅ Commands can fail, events cannot

### 2. CQRS Pattern

**Separate read and write models:**

```go
// Write side - Command
type CreateAccountCommand struct {
    TenantID  uuid.UUID
    UserID    uuid.UUID
    Currency  string
    AccountType AccountType
}

// Write side - Command handler
type CreateAccountHandler struct {
    repo eventhorizon.AggregateStore
}

func (h *CreateAccountHandler) Handle(ctx context.Context, cmd *CreateAccountCommand) error {
    agg := NewAccountAggregate(uuid.New())
    if err := agg.HandleCommand(ctx, cmd); err != nil {
        return err
    }
    return h.repo.Save(ctx, agg)
}

// Read side - Query
type GetAccountQuery struct {
    AccountID uuid.UUID
}

// Read side - Projection (read model)
type AccountProjection struct {
    ID            uuid.UUID      `gorm:"primaryKey"`
    TenantID      uuid.UUID      `gorm:"index"`
    UserID        uuid.UUID      `gorm:"index"`
    Balance       decimal.Decimal `gorm:"type:decimal(20,8)"`
    Currency      string         `gorm:"size:3"`
    Status        string         `gorm:"size:20;index"`
    CreatedAt     time.Time
    UpdatedAt     time.Time
}

// Read side - Query handler
type GetAccountQueryHandler struct {
    db *gorm.DB
}

func (h *GetAccountQueryHandler) Handle(ctx context.Context, q *GetAccountQuery) (*AccountProjection, error) {
    var account AccountProjection
    if err := h.db.First(&account, "id = ?", q.AccountID).Error; err != nil {
        return nil, err
    }
    return &account, nil
}

// Projector - Updates read model from events
type AccountProjector struct {
    db *gorm.DB
}

func (p *AccountProjector) ProjectorType() eventhorizon.ProjectorType {
    return "account_projector"
}

func (p *AccountProjector) Project(ctx context.Context, event eventhorizon.Event) error {
    switch e := event.Data().(type) {
    case *AccountCreatedEvent:
        return p.db.Create(&AccountProjection{
            ID:        event.AggregateID(),
            TenantID:  e.TenantID,
            UserID:    e.UserID,
            Balance:   decimal.Zero,
            Currency:  e.Currency,
            Status:    "active",
            CreatedAt: event.Timestamp(),
        }).Error

    case *DepositedEvent:
        return p.db.Model(&AccountProjection{}).
            Where("id = ?", event.AggregateID()).
            Update("balance", gorm.Expr("balance + ?", e.Amount)).
            Error
    // ... other events
    }
    return nil
}
```

### 3. Value Objects

**ALWAYS immutable, with validation:**

```go
// Money value object
type Money struct {
    amount   decimal.Decimal
    currency string
}

func NewMoney(amount decimal.Decimal, currency string) (Money, error) {
    if !isValidCurrency(currency) {
        return Money{}, ErrInvalidCurrency
    }
    return Money{amount: amount, currency: currency}, nil
}

func (m Money) Amount() decimal.Decimal { return m.amount }
func (m Money) Currency() string        { return m.currency }

func (m Money) Add(other Money) (Money, error) {
    if m.currency != other.currency {
        return Money{}, ErrCurrencyMismatch
    }
    return Money{
        amount:   m.amount.Add(other.amount),
        currency: m.currency,
    }, nil
}

func (m Money) IsZero() bool {
    return m.amount.IsZero()
}
```

### 4. Temporal Workflows

**For complex multi-step operations:**

```go
import "go.temporal.io/sdk/workflow"

// Workflow definition
func DepositWorkflow(ctx workflow.Context, input DepositWorkflowInput) error {
    ao := workflow.ActivityOptions{
        StartToCloseTimeout: 10 * time.Minute,
    }
    ctx = workflow.WithActivityOptions(ctx, ao)

    // Step 1: Process Stripe payment
    var paymentResult StripePaymentResult
    err := workflow.ExecuteActivity(ctx, ProcessStripePaymentActivity, input.PaymentIntent).Get(ctx, &paymentResult)
    if err != nil {
        return err
    }

    // Step 2: Credit account
    var depositResult DepositResult
    err = workflow.ExecuteActivity(ctx, CreditAccountActivity, CreditAccountInput{
        AccountID: input.AccountID,
        Amount:    paymentResult.Amount,
        Reference: paymentResult.PaymentID,
    }).Get(ctx, &depositResult)
    if err != nil {
        // Compensate: Refund Stripe payment
        workflow.ExecuteActivity(ctx, RefundStripePaymentActivity, paymentResult.PaymentID)
        return err
    }

    // Step 3: Send notification
    workflow.ExecuteActivity(ctx, SendDepositNotificationActivity, input.UserID)

    return nil
}

// Activity
func ProcessStripePaymentActivity(ctx context.Context, paymentIntentID string) (StripePaymentResult, error) {
    // Call Stripe API
    // ...
}
```

