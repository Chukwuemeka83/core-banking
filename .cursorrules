## 📊 Performance Optimization

### Database Indexes

```go
// ✅ ALWAYS add indexes for frequent queries
type AccountProjection struct {
    ID        uuid.UUID `gorm:"primaryKey"`
    TenantID  uuid.UUID `gorm:"index:idx_tenant_user,priority:1"`
    UserID    uuid.UUID `gorm:"index:idx_tenant_user,priority:2"`
    Status    string    `gorm:"index"`
    CreatedAt time.Time `gorm:"index"`
}

// Composite index
type TransactionProjection struct {
    ID        uuid.UUID `gorm:"primaryKey"`
    AccountID uuid.UUID `gorm:"index:idx_account_created,priority:1"`
    CreatedAt time.Time `gorm:"index:idx_account_created,priority:2"`
}
```

### Caching

```go
import "github.com/redis/go-redis/v9"

// ✅ Cache frequently accessed data
func (r *AccountRepository) GetAccount(ctx context.Context, id uuid.UUID) (*Account, error) {
    // Check cache first
    cacheKey := fmt.Sprintf("account:%s", id)
    cached, err := r.redis.Get(ctx, cacheKey).Result()
    if err == nil {
        var account Account
        json.Unmarshal([]byte(cached), &account)
        return &account, nil
    }

    // Cache miss - fetch from DB
    var account AccountProjection
    err = r.db.First(&account, "id = ?", id).Error
    if err != nil {
        return nil, err
    }

    // Update cache
    data, _ := json.Marshal(account)
    r.redis.Set(ctx, cacheKey, data, 5*time.Minute)

    return &account, nil
}
```

### Batch Operations

```go
// ✅ GOOD: Batch insert
func (r *TransactionRepository) CreateBatch(ctx context.Context, txs []*Transaction) error {
    return r.db.CreateInBatches(txs, 100).Error
}

// ❌ BAD: Individual inserts in loop
func (r *TransactionRepository) CreateBatch(ctx context.Context, txs []*Transaction) error {
    for _, tx := range txs {
        if err := r.db.Create(tx).Error; err != nil {
            return err
        }
    }
    return nil
}
```

