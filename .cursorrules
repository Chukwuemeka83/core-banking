## 🚀 Coding Standards

### Go Code Style

**Follow Effective Go and these additional rules:**

```go
// ✅ GOOD: Clear variable names
func calculateTotalBalance(accounts []Account) decimal.Decimal {
    total := decimal.Zero
    for _, account := range accounts {
        total = total.Add(account.Balance)
    }
    return total
}

// ❌ BAD: Unclear abbreviations
func calcTot(accs []Account) decimal.Decimal {
    t := decimal.Zero
    for _, a := range accs {
        t = t.Add(a.Bal)
    }
    return t
}

// ✅ GOOD: Early returns
func validateDeposit(amount decimal.Decimal) error {
    if amount.LessThanOrEqual(decimal.Zero) {
        return ErrInvalidAmount
    }
    if amount.GreaterThan(maxDepositAmount) {
        return ErrAmountTooLarge
    }
    return nil
}

// ❌ BAD: Nested if statements
func validateDeposit(amount decimal.Decimal) error {
    if amount.GreaterThan(decimal.Zero) {
        if amount.LessThanOrEqual(maxDepositAmount) {
            return nil
        } else {
            return ErrAmountTooLarge
        }
    } else {
        return ErrInvalidAmount
    }
}

// ✅ GOOD: Interface segregation
type AccountReader interface {
    GetAccount(ctx context.Context, id uuid.UUID) (*Account, error)
}

type AccountWriter interface {
    CreateAccount(ctx context.Context, cmd *CreateAccountCommand) error
}

// ❌ BAD: God interface
type AccountService interface {
    GetAccount(ctx context.Context, id uuid.UUID) (*Account, error)
    CreateAccount(ctx context.Context, cmd *CreateAccountCommand) error
    UpdateAccount(ctx context.Context, cmd *UpdateAccountCommand) error
    DeleteAccount(ctx context.Context, id uuid.UUID) error
    ListAccounts(ctx context.Context) ([]*Account, error)
    // ... 20 more methods
}
```

### Error Handling

```go
// ✅ GOOD: Wrap errors with context
if err := repo.Save(ctx, account); err != nil {
    return fmt.Errorf("failed to save account %s: %w", account.ID, err)
}

// ✅ GOOD: Custom error types
var (
    ErrAccountNotFound = errors.New("account not found")
    ErrInsufficientFunds = errors.New("insufficient funds")
    ErrAccountFrozen = errors.New("account is frozen")
)

type ValidationError struct {
    Field   string
    Message string
}

func (e *ValidationError) Error() string {
    return fmt.Sprintf("%s: %s", e.Field, e.Message)
}

// ✅ GOOD: Error checking
account, err := repo.GetAccount(ctx, accountID)
if err != nil {
    if errors.Is(err, ErrAccountNotFound) {
        return nil, status.Error(codes.NotFound, "account not found")
    }
    return nil, status.Error(codes.Internal, "internal error")
}
```

### Logging

```go
import "go.uber.org/zap"

// ✅ GOOD: Structured logging
logger.Info("account created",
    zap.String("account_id", accountID.String()),
    zap.String("tenant_id", tenantID.String()),
    zap.String("currency", currency),
)

logger.Error("failed to process deposit",
    zap.String("account_id", accountID.String()),
    zap.String("amount", amount.String()),
    zap.Error(err),
)

// ❌ BAD: Unstructured logging
log.Printf("Account created: %s", accountID)
log.Printf("Error: %v", err)
```

### Naming Conventions

```go
// Packages: lowercase, single word
package account
package payment

// Files: snake_case
account_aggregate.go
deposit_command.go

// Types: PascalCase
type AccountAggregate struct {}
type DepositCommand struct {}

// Interfaces: -er suffix
type AccountRepository interface {}
type EventPublisher interface {}

// Constants: PascalCase or SCREAMING_SNAKE_CASE
const MaxDepositAmount = 1000000
const DEFAULT_CURRENCY = "USD"

// Variables: camelCase
var accountID uuid.UUID
var depositAmount decimal.Decimal

// Functions: camelCase (private), PascalCase (public)
func calculateBalance() {}
func ValidateAccount() {}
```

